# SQLite（預設在啟動目錄產生 medintro.db）
DATABASE_URL=sqlite:///./medintro.db

# CORS — comma-separated origins for Vue dev server etc.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- SMTP 寄信（smtplib）---
# 開啟後始終需要：SMTP_HOST、MAIL_FROM_ADDRESS
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_account@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM_ADDRESS=your_account@gmail.com
MAIL_FROM_NAME=MedIntro POC
# 僅本機測試：開放 POST /api/mail/test-send
MAIL_TEST_ENDPOINT_ENABLED=false

# 除錯：應用程式 log 層級（DEBUG 可看 EHLO 回應長度等）
LOG_LEVEL=INFO
# 除錯：SMTP 協定層級（非常冗長，輸出到 stderr）
MAIL_SMTP_PROTOCOL_DEBUG=false

# --- 候診預警（排程會呼叫寄信，與手動 POST /api/queue/warning-scan-now 同源）---
SCHEDULER_ENABLED=true
WARNING_POLL_INTERVAL_SECONDS=60
# APScheduler 區間作業「第一次」要等滿這段秒數；設 true 則啟動時立刻跑一次
WARNING_SCAN_ON_STARTUP=true
# Maps 尚未帶回交通時間時，DB 為 null 會先代入以下分鐘（搭配等候公式：wait − travel ≤ 5 才寄）
WARNING_TRAVEL_MINUTES_FALLBACK=25

# --- Google Maps（Geocoding + Routes API；金鑰限後端，勿寫進前端）---
# 在 GCP 啟用 Geocoding API、Routes API（computeRoutes）
GOOGLE_MAPS_API_KEY=
# 診所：二擇一——(1) 直接座標 或 (2) 地址（啟動時 Geocoding 快取）
CLINIC_LATITUDE=
CLINIC_LONGITUDE=
CLINIC_ADDRESS=
MAPS_REGION_CODE=TW
# 除錯：是否額外印出 Geocoding/Routes 成功回應的 JSON 摘要（失敗時仍會印部分回應）
MAPS_DEBUG_LOG_BODIES=false

# --- LINE Messaging API（ngrok：https://你的域名/api/line/webhook）---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# LINE 掛號「不提供 GPS」時：預估等候 ≤ 此分鐘數即發預警（預設 15）
LINE_STATIC_REMINDER_MINUTES=15
LINE_TEST_ENDPOINT_ENABLED=false

# --- pyngrok 自動穿透（開發／LINE Webhook POC；上线請關閉）---
# Authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_ENABLED=false
NGROK_AUTHTOKEN=
# 必須與 uvicorn --port 相同
NGROK_LISTEN_PORT=8000
